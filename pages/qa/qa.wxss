.page-qa {
  position: relative;
  min-height: 100vh;
  padding: 24rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.scroll {
  height: 100%;
}

.header {
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.search-row {
  margin-top: 24rpx;
}

.search-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 999rpx;
  background-color: #f2f2f2;
  font-size: 24rpx;
  box-sizing: border-box;
}

.search-placeholder {
  color: #b3b3b3;
}

.category {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.category-item {
  align-items: center;
  display: flex;
  flex-direction: column;
}

.category-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  align-items: center;
  justify-content: center;
  display: flex;
  font-size: 32rpx;
  font-weight: 600;
}

.category-icon-blue {
  background-color: #e6f0ff;
  color: #2f54eb;
}

.category-icon-pink {
  background-color: #ffe6f1;
  color: #eb2f96;
}

.category-icon-yellow {
  background-color: #fff7e6;
  color: #faad14;
}

.category-icon-green {
  background-color: #e6fffb;
  color: #13c2c2;
}

.category-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #555555;
}

.section {
  margin-top: 8rpx;
}

.section-title {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.qa-card {
  margin-top: 16rpx;
}

.qa-title-row {
  flex-direction: row;
  display: flex;
  align-items: flex-start;
}

.qa-tag-hot,
.qa-tag-new {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  color: #ffffff;
  margin-right: 12rpx;
}

.qa-tag-hot {
  background-color: #fa8c16;
}

.qa-tag-new {
  background-color: #52c41a;
}

.qa-title {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
}

.qa-brief {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #666666;
}

.qa-brief-empty {
  font-style: italic;
}

.qa-footer {
  margin-top: 16rpx;
  flex-direction: row;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.qa-meta {
  font-size: 20rpx;
  color: #999999;
}

.qa-chip {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background-color: #f5f5f5;
  color: #666666;
}

.ask-fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background-color: #07c160;
  align-items: center;
  justify-content: center;
  display: flex;
  box-shadow: 0 16rpx 32rpx rgba(7, 193, 96, 0.3);
}

.ask-fab-icon {
  font-size: 44rpx;
  color: #ffffff;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.05);
}
