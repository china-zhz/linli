            <view class="owner">
              <view class="owner-avatar"></view>
              <text class="owner-name">小林</text>
            </view>
            <text class="owner-building">15栋</text>
          </view>
        </view>
      </view>

      <!-- 商品 3 -->
      <view class="product card">
