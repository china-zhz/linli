.page-help {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.scroll {
  height: 100%;
}

.header {
  margin-bottom: 24rpx;
}

.header-row {
  flex-direction: row;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.points {
  flex-direction: row;
  display: flex;
  align-items: center;
  color: #07c160;
}

.points-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.points-text {
  font-size: 26rpx;
  font-weight: 600;
}

.switch-row {
  margin-top: 24rpx;
  background-color: #f2f2f2;
  border-radius: 999rpx;
  padding: 4rpx;
  flex-direction: row;
  display: flex;
}

.switch-btn {
  flex: 1;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  display: flex;
  padding: 12rpx 0;
}

.switch-btn-active {
  background-color: #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.04);
}

.switch-text {
  font-size: 24rpx;
  color: #666666;
}

.switch-text-active {
  color: #07c160;
  font-weight: 600;
}

.help-card {
  margin-top: 24rpx;
  border-left-width: 8rpx;
  border-left-style: solid;
}

.help-card-orange {
  border-left-color: #fa8c16;
}

.help-card-blue {
  border-left-color: #1890ff;
}

.help-card-green {
  border-left-color: #52c41a;
}

.help-top {
  flex-direction: row;
  display: flex;
  justify-content: space-between;
}

.help-left {
  flex: 1;
}

.help-right {
  align-items: flex-end;
  display: flex;
  flex-direction: column;
}

.help-badge {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.help-badge-orange {
  background-color: #fff7e6;
  color: #fa8c16;
}

.help-badge-blue {
  background-color: #e6f7ff;
  color: #1890ff;
}

.help-badge-green {
  background-color: #f6ffed;
  color: #52c41a;
}

.help-title {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.help-points {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 600;
}

.help-time {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #aaaaaa;
}

.help-desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.help-footer {
  margin-top: 20rpx;
  flex-direction: row;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user {
  flex-direction: row;
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background-color: #dddddd;
  margin-right: 12rpx;
}

.user-name {
  font-size: 22rpx;
  color: #888888;
}

.help-btn {
  padding: 10rpx 32rpx;
  border-radius: 999rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
}

.honor {
  margin-top: 24rpx;
  background-image: linear-gradient(135deg, #f6ffed, #e6fffb);
}

.honor-title-row {
  flex-direction: row;
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.honor-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.honor-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #237804;
}

.honor-row {
  flex-direction: row;
  display: flex;
  justify-content: space-between;
}

.honor-item {
  align-items: center;
  display: flex;
  flex-direction: column;
}

.honor-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #ffffff;
  margin-bottom: 8rpx;
}

.honor-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #555555;
}

.honor-meta {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #389e0d;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.05);
}
